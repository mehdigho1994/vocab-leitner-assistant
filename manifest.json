{
  "manifest_version": 3,
  "name": "Vocab Leitner Assistant",
  "version": "1.8.6",
  "description": "Dictionary, translation, pronunciation, and Leitner vocabulary review while browsing.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://api.datamuse.com/*",
    "https://api.dictionaryapi.dev/*",
    "https://api.mymemory.translated.net/*",
    "https://translate.argosopentech.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Vocab Leitner Assistant",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.svg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}